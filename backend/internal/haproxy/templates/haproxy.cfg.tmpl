# HAProxy Configuration Template
# Generated by Isolate Panel - Dynamic Port Allocation System
# DO NOT EDIT MANUALLY - This file is auto-generated

# =============================================================================
# GLOBAL SECTION
# =============================================================================
global
    # Logging configuration
    log stdout local0

    # Maximum concurrent connections
    maxconn 4096

    # Stats socket for runtime management (reload, health checks)
    # Required for HAProxy reload without dropping connections
    stats socket /run/haproxy/admin.sock mode 600 level admin

    # Tune settings for better performance
    tune.ssl.default-dh-param 2048

# =============================================================================
# DEFAULTS SECTION
# =============================================================================
defaults
    # Default mode: TCP for most proxy protocols
    mode tcp

    # Timeouts
    timeout connect 5s
    timeout client 30s
    timeout server 30s

    # Logging
    log global

    # Error handling
    option dontlognull
    option redispatch
    retries 3

# =============================================================================
# DYNAMIC FRONTENDS
# Grouped by user_listen_port for multi-inbound support
# =============================================================================
{{range $port, $group := .PortGroups}}
# Frontend for user port {{$port}}
# Contains {{$group.Backends | len}} backend(s)
frontend ft_user_{{$port}}
    # Bind with IPv4/IPv6 support and TCP Fast Open
    bind :{{$port}} v4v6 tfo

    {{if $group.HasTLS}}
    # TLS configuration
    bind :{{$port}} v4v6 tfo ssl crt /etc/certs/fullchain.pem
    {{end}}

    # Mode: TCP for SNI routing, HTTP for path-based routing
    mode {{$group.Mode}}

    {{if $group.HasTLS}}
    # SNI inspection delay - allows HAProxy to read SNI from TLS ClientHello
    tcp-request inspect-delay 5s
    tcp-request content accept if { req_ssl_hello_type 1 }
    {{end}}

    {{if $group.HasSNI}}
    # SNI-based routing rules
    {{range $backend := $group.Backends}}
    {{if $backend.SNIMatch}}
    # Route to {{$backend.Name}} via SNI: {{$backend.SNIMatch}}
    acl is_{{$backend.Name}} req.ssl_sni -i {{$backend.SNIMatch}}
    use_backend {{$backend.BackendName}} if is_{{$backend.Name}}
    {{end}}
    {{end}}
    {{end}}

    {{if $group.HasPath}}
    # Path-based routing rules (HTTP mode only)
    {{range $backend := $group.Backends}}
    {{if $backend.PathMatch}}
    # Route to {{$backend.Name}} via path: {{$backend.PathMatch}}
    use_backend {{$backend.BackendName}} if { path_beg {{$backend.PathMatch}} }
    {{end}}
    {{end}}
    {{end}}

    # Default backend - panel web UI or fallback
    default_backend bk_default_web

{{end}}

# =============================================================================
# DYNAMIC BACKENDS
# One backend per inbound assignment
# =============================================================================
{{range .Backends}}
# Backend for {{.Name}}
# Core: {{.CoreType}}, Port: {{.BackendPort}}
backend {{.BackendName}}
    # Mode: {{.Mode}}
    mode {{.Mode}}

    {{if eq .Mode "http"}}
    # HTTP mode settings
    option http-server-close
    timeout tunnel 1h

    {{if .UseXForwardedFor}}
    # X-Forwarded-For header for Sing-box and Mihomo
    http-request set-header X-Forwarded-For %[src]
    {{end}}
    {{end}}

    {{if .SendProxyProtocol}}
    # PROXY protocol v2 for Xray TCP-based inbounds
    # Preserves real client IP
    {{end}}

    # Server configuration
    server {{.ServerName}} 127.0.0.1:{{.BackendPort}}{{if .SendProxyProtocol}} send-proxy-v2{{end}} check inter 5s

{{end}}

# =============================================================================
# DEFAULT WEB BACKEND
# Fallback for unmatched requests
# =============================================================================
backend bk_default_web
    mode http
    timeout connect 5s
    timeout client 30s
    timeout server 30s

    # Forward to panel web UI
    server panel_web 127.0.0.1:8080 check inter 5s

# =============================================================================
# LISTEN SECTION (Optional - for stats UI)
# =============================================================================
listen stats
    bind *:8404
    mode http
    stats enable
    stats uri /stats
    stats refresh 10s
    stats show-legends
    stats auth admin:{{.StatsPassword}}