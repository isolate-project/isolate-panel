{
  "name": "isolate-panel-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:live": "playwright test --config playwright.live.config.ts",
    "test:e2e:live:ui": "playwright test --config playwright.live.config.ts --ui",
    "test:e2e:live:report": "playwright show-report playwright-report-live",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tippyjs/react": "^4.2.6",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.10.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-preact": "^1.0.1",
    "preact": "^10.29.0",
    "preact-router": "^4.1.2",
    "react-chartjs-2": "^5.3.1",
    "react-i18next": "^16.6.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tippy.js": "^6.3.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.9.3",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^6.0.11",
    "vitest": "^4.1.1"
  }
}
