# =============================================================================
# Isolate Panel Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
#
# SECURITY: Use SOPS + age to encrypt this file in Git:
#   age-keygen -o age.key.txt
#   sops --encrypt --age <public-key> .env > .env.enc
#   echo "age.key.txt" >> .gitignore
#   echo "*.enc" >> .gitignore
#
# Production secrets should use Docker Compose secrets (see docker-compose.yml)
# =============================================================================

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# JWT_SECRET is auto-generated on first run and persisted in /app/data/.core-secrets
# You can override this by setting JWT_SECRET explicitly if needed

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment: development, production
APP_ENV=production

# Port for the panel API (default: 8080)
PORT=8080

# Timezone (default: UTC)
TZ=UTC

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
# In production, leave empty for same-origin policy (no CORS)
# In development, use: http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite database path (inside container)
DATABASE_PATH=/app/data/isolate-panel.db

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json, console
# LOG_FORMAT=json

# Log output: stdout, file, both
# LOG_OUTPUT=stdout

# Log file path (if LOG_OUTPUT includes file)
# LOG_FILE_PATH=/var/log/supervisor/isolate-panel.log

# Log rotation settings
# LOG_MAX_SIZE=100
# LOG_MAX_BACKUPS=3
# LOG_MAX_AGE=28
# LOG_COMPRESS=true

# Request body size limit in KB (default: 2048 = 2MB)
# APP_BODY_LIMIT=2048

# -----------------------------------------------------------------------------
# Monitoring Configuration
# -----------------------------------------------------------------------------
# Monitoring mode: lite (60s interval) or full (10s interval)
# lite:  Lower RAM usage (~30MB), less accurate stats (±1 minute)
# full:  Higher RAM usage (~100MB), more accurate stats (±10 seconds)
MONITORING_MODE=lite

# -----------------------------------------------------------------------------
# Cores Configuration (Advanced)
# -----------------------------------------------------------------------------
# API addresses for stats collection (default values shown)
# CORES_XRAY_API_ADDR=127.0.0.1:10085
# CORES_SINGBOX_API_ADDR=127.0.0.1:9090
# CORES_MIHOMO_API_ADDR=127.0.0.1:9091

# API keys for Sing-box and Mihomo (generate your own)
# CORES_SINGBOX_API_KEY=your-singbox-api-key
# CORES_MIHOMO_API_KEY=your-mihomo-api-key

# -----------------------------------------------------------------------------
# Docker Configuration (Advanced)
# -----------------------------------------------------------------------------
# Docker Content Trust — verify image signatures before running
# Enable in production to require signed images (prevents supply chain attacks)
# Set to 1 to enable, 0 or leave unset to disable
# DOCKER_CONTENT_TRUST=1

# -----------------------------------------------------------------------------
# Security Settings (Advanced)
# -----------------------------------------------------------------------------
# Argon2id password hashing parameters
# SECURITY_ARGON2_TIME=3
# SECURITY_ARGON2_MEMORY=65536
# SECURITY_ARGON2_THREADS=4
# SECURITY_ARGON2_KEY_LENGTH=32
# SECURITY_ARGON2_SALT_LENGTH=16

# -----------------------------------------------------------------------------
# Backup Settings (Phase 9 - Optional)
# -----------------------------------------------------------------------------
# BACKUP_ENABLED=false
# BACKUP_SCHEDULE=0 2 * * *
# BACKUP_RETENTION=7

# -----------------------------------------------------------------------------
# Notification Settings (Phase 10 - Optional)
# -----------------------------------------------------------------------------
# Telegram Bot Token
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Webhook URL
# WEBHOOK_URL=
# WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Admin Credentials (REQUIRED for first launch)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=  # REQUIRED: set a strong password before first launch
# ⚠️ If left empty, the app will use a default password that MUST be changed on first login

# -----------------------------------------------------------------------------
# Panel URL (Optional)
# -----------------------------------------------------------------------------
# Used as fallback for subscription link generation when no TLS certificate is bound.
# If all your inbounds have TLS certificates, the domain is extracted automatically
# from cert.Domain — this setting is NOT needed in that case.
# APP_PANEL_URL=https://your-server-ip-or-domain

# -----------------------------------------------------------------------------
# Subscription Listener Configuration (Optional)
# -----------------------------------------------------------------------------
# Host for subscription listener (default: 127.0.0.1)
# Use 0.0.0.0 to bind to all interfaces (not recommended for security)
# ISOLATE_SUBSCRIPTION_HOST=127.0.0.1

# Allow HTTP fallback when AutoTLS fails (default: false)
# In production, HTTP is disabled by default for security
# Set to true only in development or if you understand the security implications
# ISOLATE_SUBSCRIPTION_ALLOW_HTTP=false

# -----------------------------------------------------------------------------
# Cloudflare DNS API — Alternative Auth (Optional)
# -----------------------------------------------------------------------------
# Global API Key (legacy, less secure — prefer API Token above)
# CLOUDFLARE_API_KEY=your-global-api-key

# =============================================================================
# Caddy Reverse Proxy Configuration (Production)
# =============================================================================
# These settings are used when running with docker-compose.prod.yml

# Caddy admin API port (default: localhost:2019)
# CADDY_ADMIN=localhost:2019

# Enable HTTP/3 (QUIC) support (default: true)
# CADDY_HTTP3_ENABLED=true

# =============================================================================
# Backup Service Configuration (offen/docker-volume-backup)
# =============================================================================
# Generate a strong backup password: openssl rand -base64 32
# This is used to encrypt backup archives
BACKUP_PASSWORD=  # REQUIRED for production: generate with openssl rand -base64 32

# Backup notification URLs (optional)
# Comma-separated list of notification endpoints
# Supports: Discord, Slack, Telegram, generic webhooks
# BACKUP_NOTIFICATION_URLS=

# Backup schedule (default: 0 2 * * * = daily at 2 AM)
# BACKUP_SCHEDULE=0 2 * * *

# Backup retention in days (default: 7)
# BACKUP_RETENTION_DAYS=7

# =============================================================================
# Diun (Docker Image Update Notifications)
# =============================================================================
# Diun checks for Docker image updates daily

# Discord webhook URL for notifications
# DIUN_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Slack webhook URL for notifications
# DIUN_SLACK_WEBHOOK=https://hooks.slack.com/services/...

# Telegram bot token for notifications
# DIUN_TELEGRAM_BOT_TOKEN=your-bot-token

# Telegram chat ID for notifications
# DIUN_TELEGRAM_CHAT_ID=your-chat-id

# Generic webhook URL for notifications
# DIUN_WEBHOOK_URL=https://your-webhook-endpoint.com/notify

# Webhook secret for HMAC signature verification
# DIUN_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# WireGuard Panel-to-Node Tunnel (Optional)
# =============================================================================
# Enable WireGuard for encrypted panel-to-node communication over the internet
# Only needed if you have remote proxy nodes on different servers

# WireGuard server public endpoint (your VPS IP or domain)
# WIREGUARD_SERVER_URL=your-vps-ip-or-domain

# Number of peer nodes (default: 3)
# WIREGUARD_PEERS=node1,node2,node3

# =============================================================================
# Database Field Encryption (Optional)
# =============================================================================
# 32-byte base64-encoded AES-256 key for encrypting sensitive database fields
# Generate: openssl rand -base64 32
# Fields encrypted: user tokens, admin TOTP secrets, notification API keys, inbound configs
# DATA_ENCRYPTION_KEY=  # REQUIRED if encryption is enabled

# =============================================================================
# Per-Node API Keys (Optional)
# =============================================================================
# When WireGuard is enabled, each remote node gets a unique API key
# Keys are generated automatically via the admin panel
# CORE_API_ALLOWED_IPS=10.200.200.0/24,127.0.0.1/8
